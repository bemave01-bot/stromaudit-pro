{
  "title": "StromAudit Pro – Audit-Ergebnis (Dataset Schema)",
  "type": "object",
  "properties": {
    "pruefnummer": { "type": "string", "title": "Prüfnummer (eindeutig, SAP-YYYYMMDD-XXXXXXXX)" },
    "erstellt_utc": { "type": "string", "title": "Erstellungszeitpunkt (ISO 8601, UTC)" },
    "berichtsjahr": { "type": "integer", "title": "Berichtsjahr" },
    "status": { "type": "string", "title": "Status (AUDIT_READY)" },
    "plz": { "type": "string", "title": "Postleitzahl" },
    "bundesland": { "type": "string", "title": "Bundesland" },
    "netzbetreiber": { "type": "string", "title": "Regionaler Netzbetreiber" },
    "unternehmen": { "type": "string", "title": "Unternehmensbezeichnung" },
    "eingabe": {
      "type": "object", "title": "Eingabeparameter",
      "properties": {
        "jahresverbrauch_kwh": { "type": "number" },
        "spitzenlast_kw": { "type": "number" },
        "messstellenbetrieb_eur": { "type": "number" },
        "is_producing_gewerbe": { "type": "boolean" }
      }
    },
    "marktdaten": {
      "type": "object", "title": "Live-Marktdaten (SMARD/Bundesnetzagentur)",
      "properties": {
        "dayahead_preis_eur_mwh": { "type": "number", "title": "Day-Ahead Preis EUR/MWh" },
        "dayahead_preis_eur_kwh": { "type": "number", "title": "Day-Ahead Preis EUR/kWh" },
        "avg_7tage_eur_kwh": { "type": "number", "title": "7-Tage-Durchschnitt EUR/kWh" },
        "timestamp_utc": { "type": "string", "title": "Zeitstempel UTC" },
        "quelle": { "type": "string", "title": "Datenquelle" }
      }
    },
    "kalkulation": {
      "type": "object", "title": "Vollkostenberechnung",
      "properties": {
        "arbeitspreis_netto_ct_kwh": { "type": "number", "title": "Arbeitspreis netto (ct/kWh)" },
        "jahresarbeitspreis_netto_eur": { "type": "number", "title": "Jahresarbeitspreis netto (EUR)" },
        "leistungskosten_netto_eur": { "type": "number", "title": "Leistungskosten netto (EUR)" },
        "messstellenbetrieb_eur": { "type": "number", "title": "Messstellenbetrieb (EUR)" },
        "netto_gesamt_eur": { "type": "number", "title": "Netto-Gesamtkosten (EUR)" },
        "mwst_eur": { "type": "number", "title": "MwSt. 19% (EUR)" },
        "brutto_gesamt_eur": { "type": "number", "title": "Brutto-Gesamtkosten (EUR)" },
        "stromsteuer_entlastung_9b_eur": { "type": "number", "title": "§9b StromStG Entlastung (EUR)" },
        "stromnev_kategorie": { "type": "string", "title": "§19 StromNEV Kategorie" },
        "aufschluesselung": { "type": "object", "title": "Kostenaufschlüsselung nach Komponente" },
        "tarife_angewendet": { "type": "object", "title": "Angewendete Tarifsätze 2026" }
      }
    },
    "esg": {
      "type": "object", "title": "ESG / CO₂-Bilanz (Scope 2, ESRS E1)",
      "properties": {
        "scope": { "type": "string" },
        "norm": { "type": "string" },
        "emissionsfaktor_g_co2_kwh": { "type": "number" },
        "co2_footprint_kg": { "type": "number" },
        "co2_footprint_tonnen": { "type": "number" },
        "eu_taxonomy": { "type": "string" },
        "csrd_relevant": { "type": "boolean" }
      }
    },
    "compliance": {
      "type": "object", "title": "Compliance-Checkliste",
      "properties": {
        "checks": { "type": "array", "items": { "type": "object" } },
        "compliance_score": { "type": "number", "title": "Compliance-Score (0–100)" }
      }
    },
    "report_url": { "type": "string", "title": "URL zum HTML Audit-Bericht (Apify KV-Store)" },
    "gesetzliche_grundlagen": { "type": "array", "items": { "type": "string" }, "title": "Rechtsgrundlagen" },
    "tool_version": { "type": "string", "title": "StromAudit Pro Version" }
  }
}
